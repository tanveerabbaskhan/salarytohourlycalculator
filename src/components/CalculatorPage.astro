---
import { getPagePaths } from '../config/paths';
import { getHomepageContent } from '../content/homepage';
import { getLocalization } from '../i18n/localization';
import SalaryCalculator from './SalaryCalculator.astro';

interface Props {
  language: string;
}

const { language } = Astro.props as Props;
const strings = getLocalization(language);
const content = getHomepageContent(language);
const pagePaths = getPagePaths(language);
---

<section class="calculator-page">
  <div class="container">
    <h1 class="page-title">{pagePaths.h1 || strings.wageCalculator}</h1>
    <p class="page-description">{content.subheadline}</p>

    <section class="calculator-section" aria-label={strings.calculatorAria}>
      <SalaryCalculator currency="USD" strings={strings} language={language} />
    </section>

    <section class="seo-content">
      <h2>{content.howTitle}</h2>
      <p>{content.howIntro}</p>
      <div class="content-grid">
        {content.steps.map(step => (
          <article>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </article>
        ))}
      </div>

      <h2>{content.formulasTitle}</h2>
      <p>{content.formulasIntro}</p>
      <div class="content-grid">
        {content.formulas.map(formula => (
          <article>
            <h3>{formula.title}</h3>
            <p>{formula.text}</p>
          </article>
        ))}
      </div>

      <h2>{content.whyTitle}</h2>
      {content.whyText.map(paragraph => <p>{paragraph}</p>)}

      <h2>{content.faqTitle}</h2>
      {content.faqs.map(item => (
        <div class="faq-item">
          <h3>{item.question}</h3>
          <p>{item.answer}</p>
        </div>
      ))}
    </section>
  </div>
</section>

<style>
  .calculator-page {
    padding: var(--spacing-2xl) 0;
  }

  .page-title {
    margin-bottom: var(--spacing-lg);
    font-size: var(--font-size-3xl);
    font-weight: 700;
    text-align: center;
  }

  .page-description {
    max-width: 800px;
    margin: 0 auto var(--spacing-2xl);
    color: var(--color-text-light);
    font-size: var(--font-size-lg);
    text-align: center;
  }

  .calculator-section {
    margin: var(--spacing-2xl) 0;
    padding: var(--spacing-xl);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    background-color: var(--color-bg-light);
  }

  .seo-content {
    margin-top: var(--spacing-2xl);
    line-height: 1.8;
  }

  .seo-content h2 {
    margin-top: var(--spacing-2xl);
    margin-bottom: var(--spacing-lg);
    font-size: var(--font-size-2xl);
    font-weight: 600;
    scroll-margin-top: 80px;
  }

  .seo-content h3 {
    margin-top: 0;
    margin-bottom: var(--spacing-md);
    font-size: var(--font-size-lg);
    font-weight: 600;
  }

  .seo-content p {
    margin-bottom: var(--spacing-md);
    color: var(--color-text-light);
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--spacing-md);
    margin: var(--spacing-lg) 0;
  }

  .content-grid article,
  .faq-item {
    padding: var(--spacing-lg);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    background-color: var(--color-bg-light);
  }

  .faq-item {
    margin: var(--spacing-lg) 0;
    border-left: 4px solid var(--color-primary);
  }

  .faq-item h3 {
    color: var(--color-primary);
  }

  .faq-item p {
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: var(--font-size-2xl);
    }

    .calculator-section {
      padding: var(--spacing-lg);
    }

    .seo-content h2 {
      font-size: var(--font-size-xl);
    }

    .content-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
