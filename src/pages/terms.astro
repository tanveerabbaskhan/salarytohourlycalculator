---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Terms of Service | Salary to Hourly Calculator';
const description = 'Terms of service for Salary to Hourly Calculator.';
---

<BaseLayout language="en" title={title} description={description} canonical="/terms/" hreflangGroup="none">
  <article class="page-content">
    <h1>Terms of Service</h1>
    <p>
      By using Salary to Hourly Calculator, you agree to use the site for informational purposes only.
    </p>
    <h2>No financial or legal advice</h2>
    <p>
      The calculator provides estimates based on standard assumptions. It does not provide tax,
      legal, payroll, or financial advice.
    </p>
    <h2>Accuracy</h2>
    <p>
      We aim to keep calculations clear and useful, but results may differ from employer payroll
      systems, local labor rules, overtime policies, benefits, and tax treatment.
    </p>
    <h2>Use of the site</h2>
    <p>
      You may use the calculator for personal or professional comparison, but you are responsible
      for verifying important compensation decisions with qualified professionals.
    </p>
  </article>
</BaseLayout>

<style>
  .page-content {
    max-width: 820px;
    margin: 0 auto;
    line-height: 1.8;
  }

  .page-content h1 {
    font-size: var(--font-size-3xl);
    margin-bottom: var(--spacing-lg);
  }

  .page-content h2 {
    margin-top: var(--spacing-xl);
  }

  .page-content p {
    color: var(--color-text-light);
  }
</style>
