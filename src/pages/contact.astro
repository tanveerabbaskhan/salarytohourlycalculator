---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Contact | Salary to Hourly Calculator';
const description = 'Contact Salary to Hourly Calculator for feedback, corrections, and questions.';
---

<BaseLayout language="en" title={title} description={description} canonical="/contact/" hreflangGroup="none">
  <article class="page-content">
    <h1>Contact</h1>
    <p>
      Have feedback, found an issue, or want to suggest another calculator? Send a note to
      support@salarytohourly.com.
    </p>
    <h2>What to include</h2>
    <p>
      If you are reporting a calculator issue, include the wage value, pay period, hours per week,
      currency, and the result you expected.
    </p>
    <p>
      We cannot provide personal tax, legal, or payroll advice, but clear issue reports help improve
      the tool for everyone.
    </p>
  </article>
</BaseLayout>

<style>
  .page-content {
    max-width: 820px;
    margin: 0 auto;
    line-height: 1.8;
  }

  .page-content h1 {
    font-size: var(--font-size-3xl);
    margin-bottom: var(--spacing-lg);
  }

  .page-content h2 {
    margin-top: var(--spacing-xl);
  }

  .page-content p {
    color: var(--color-text-light);
  }
</style>
